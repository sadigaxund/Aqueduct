# Copy to `.env` to override defaults. Compose works without it.
# Only the drift / heal demo reads these — happy path needs nothing.
#
# Defaults point at Ollama on the host. Pull the model first:
#   ollama pull qwen2.5-coder:7b

AQ_OLLAMA_URL=http://host.docker.internal:11434
AQ_OLLAMA_MODEL=qwen2.5-coder:7b
