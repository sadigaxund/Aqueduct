# Self-Healing Showcase — copy this to .env and adjust as needed.
# Every value already has a working default (shown after :-) in
# aqueduct.yml / blueprints/showcase_orders.yml — this file is optional.

# ── Agent connectivity (OpenAI-compatible endpoint — Ollama by default) ──
AQ_OLLAMA_URL=http://localhost:11434
AQ_OLLAMA_MODEL=qwen2.5-coder:7b

# ── Agent budget (per-heal-attempt caps). Defaults are generous ceilings
#    for a slow/local/cold-start model — shrink for faster iteration
#    against a fast remote endpoint. ─────────────────────────────────
AQ_AGENT_TIMEOUT=12000.0
AQ_AGENT_MAX_REPROMPTS=4
AQ_AGENT_MAX_SECONDS=12000
AQ_AGENT_MAX_TOKENS=20000

# ── Blueprint context (${ctx.env} — no functional effect on this demo,
#    just threaded through to show the Context Registry) ──────────────
AQ_ENV=dev

# ── Lifecycle hooks — webhook receiver base URL. Point this at a real
#    listener to see the on_success/on_failure POST land instead of 404
#    (e.g. gallery/snippets/42_hooks_lifecycle ships one). ─────────────
AQ_WEBHOOK_BASE=http://localhost:9999
