# aqueduct.yml — Engine Configuration Template
#
# Configures the Aqueduct engine: deployment, Spark, stores, probes, secrets,
# webhooks, and LLM agent connection. NOT a blueprint definition.
#
# Rename to aqueduct.yml and place in your project root (or pass with --config).
# All sections are optional — omitting this file entirely uses local Spark with
# DuckDB stores in .aqueduct/.
#
# CLI flags override values here. Blueprint spark_config overrides spark_config
# below (Blueprint wins on conflict). LLM policy (approval_mode, forbidden_ops)
# belongs in each Blueprint's agent: block — not here.
#
# Usage:
#   aqueduct run blueprint.yml                       # auto-discovers aqueduct.yml in CWD
#   aqueduct run blueprint.yml --config aqueduct.yml
#   aqueduct validate aqueduct.yml                  # static check (no run)

aqueduct_config: "1.0"

  
# ── Deployment ────────────────────────────────────────────────────────────────

deployment:
  # engine: execution engine. Currently supported: spark. Planned: flink.
  engine: spark

  # target: informational label only — never changes execution behaviour.
  # Use it to tag the environment for monitoring/logging.
  # Values: local | standalone | yarn | kubernetes | databricks | emr | dataproc
  target: local

  # master_url: passed verbatim to SparkSession.builder.master()
  master_url: "local[*]"
  # master_url: "local[4]"                         # 4 threads
  # master_url: "spark://host:7077"                # Spark Standalone
  # master_url: "yarn"                             # YARN (needs HADOOP_CONF_DIR)
  # master_url: "k8s://https://k8s-apiserver:443"  # Kubernetes
  # master_url: "sc://databricks-host:443"         # Databricks Connect

  # env: deployment environment tier.
  # local (default) — dev machine, no cluster validation.
  # cluster — standalone/YARN/K8s; doctor errors on relative store paths.
  # cloud   — managed cloud (Databricks/EMR/Dataproc); same validation as cluster.
  env: local
  # env: cluster


# ── Spark Configuration ───────────────────────────────────────────────────────
#
# Any spark.* key accepted. Merged with Blueprint spark_config at runtime;
# Blueprint values win on conflict.

spark_config: {}

  # ── Object storage — MinIO / S3-compatible ──────────────────────────────────
  # spark.hadoop.fs.s3a.endpoint: "http://minio:9000"
  # spark.hadoop.fs.s3a.path.style.access: "true"
  # spark.hadoop.fs.s3a.access.key: "@aq.secret('MINIO_ACCESS_KEY')"
  # spark.hadoop.fs.s3a.secret.key: "@aq.secret('MINIO_SECRET_KEY')"
  # spark.jars.packages: "org.apache.hadoop:hadoop-aws:3.3.4"

  # ── Object storage — AWS S3 (IAM role or key-pair) ──────────────────────────
  # spark.hadoop.fs.s3a.aws.credentials.provider: "com.amazonaws.auth.InstanceProfileCredentialsProvider"
  # spark.hadoop.fs.s3a.access.key: "@aq.secret('AWS_ACCESS_KEY_ID')"
  # spark.hadoop.fs.s3a.secret.key: "@aq.secret('AWS_SECRET_ACCESS_KEY')"
  # spark.jars.packages: "org.apache.hadoop:hadoop-aws:3.3.4"

  # ── Object storage — Google Cloud Storage ───────────────────────────────────
  # spark.hadoop.google.cloud.auth.service.account.enable: "true"
  # spark.hadoop.google.cloud.auth.service.account.json.keyfile: "/secrets/gcp-key.json"
  # spark.jars.packages: "com.google.cloud.bigdataoss:gcs-connector:hadoop3-2.2.11"

  # ── JDBC ────────────────────────────────────────────────────────────────────
  # spark.jars: "/opt/jars/postgresql-42.6.0.jar"
  # spark.jars.packages: "org.postgresql:postgresql:42.6.0"

  # ── Delta Lake ──────────────────────────────────────────────────────────────
  # spark.jars.packages: "io.delta:delta-spark_2.12:3.2.0"
  # spark.sql.extensions: "io.delta.sql.DeltaSparkSessionExtension"
  # spark.sql.catalog.spark_catalog: "org.apache.spark.sql.delta.catalog.DeltaCatalog"

  # ── Resource sizing ─────────────────────────────────────────────────────────
  # spark.driver.memory: "4g"
  # spark.executor.memory: "8g"
  # spark.executor.cores: "4"
  # spark.executor.instances: "10"
  # spark.sql.shuffle.partitions: "200"

  # ── Serialization ───────────────────────────────────────────────────────────
  # spark.serializer: "org.apache.spark.serializer.KryoSerializer"

  # ── Adaptive Query Execution (Spark 3+) ─────────────────────────────────────
  # spark.sql.adaptive.enabled: "true"
  # spark.sql.adaptive.coalescePartitions.enabled: "true"


# ── Stores ────────────────────────────────────────────────────────────────────
#
# Phase 28: each store is pluggable. Default DuckDB layout under .aqueduct/:
#   observability.db      — run records, failure contexts, signal overrides, probe
#                 signals, module + maintenance metrics, healing outcomes
#   lineage.db  — column-level lineage
#   depot.db    — depot KV store (@aq.depot.*)
#   snapshots/  — schema_snapshot JSON files (one file per probe per run)
#
# Supported backends:
#   duckdb    — embedded; single-writer file. Suits local / dev / NFS.
#               Accepted by obs / lineage / depot.
#   postgres  — networked DSN; MVCC concurrent writers. Accepted by all
#               three stores. With a shared DSN the engine creates `observability`,
#               `lineage`, `depot` schemas inside the target database.
#   redis     — depot-only KV; rejected at config-load for obs / lineage.
#
# `aqueduct stores info` prints the resolved backend per store.
# `aqueduct stores migrate --from-duckdb <old.db>` copies depot KV rows.

stores:

  observability:
    backend: duckdb
    path: ".aqueduct/observability.db"
    # Postgres example (uncomment + install `aqueduct-core[postgres]`):
    # backend: postgres
    # path: "postgresql://aq@host:5432/aqueduct_db"

  lineage:
    backend: duckdb
    path: ".aqueduct/lineage.db"
    # backend: postgres
    # path: "postgresql://aq@host:5432/aqueduct_db"

  depot:
    backend: duckdb
    path: ".aqueduct/depot.db"
    # backend: postgres
    # path: "postgresql://aq@host:5432/aqueduct_db"
    # Redis-only fast-path (uncomment + install `aqueduct-core[redis]`):
    # backend: redis
    # path: "redis://host:6379/0"


# ── Cluster / Cloud deployment example ───────────────────────────────────────
#
# For YARN, Kubernetes, Spark Standalone, or Databricks/EMR/Dataproc:
#
#   1. Set deployment.env: cluster (triggers doctor validation of store paths)
#   2. Set master_url to your cluster endpoint
#   3. Set all store paths to absolute paths on shared FS (NFS/EFS/PVC)
#      — driver CWD is ephemeral on YARN/K8s; relative paths lose data on restart
#   4. Move all hadoop FS credentials into spark_config (not Ingress options)
#
# Example (Spark Standalone + NFS shared store + S3A data):
#
# deployment:
#   target: standalone
#   master_url: "spark://spark-master.internal:7077"
#   env: cluster
#
# stores:
#   obs:
#     backend: duckdb
#     path: "/mnt/nfs/aqueduct/observability.db"
#   lineage:
#     backend: duckdb
#     path: "/mnt/nfs/aqueduct/lineage.db"
#   depot:
#     backend: duckdb
#     path: "/mnt/nfs/aqueduct/depot.db"
#
# spark_config:
#   spark.executor.memory: "8g"
#   spark.executor.cores: "4"
#   spark.executor.instances: "20"
#   spark.jars.packages: "org.apache.hadoop:hadoop-aws:3.3.4,io.delta:delta-spark_2.12:3.2.0"
#   spark.sql.extensions: "io.delta.sql.DeltaSparkSessionExtension"
#   spark.sql.catalog.spark_catalog: "org.apache.spark.sql.delta.catalog.DeltaCatalog"
#   spark.hadoop.fs.s3a.aws.credentials.provider: "com.amazonaws.auth.InstanceProfileCredentialsProvider"


# ── Probes ────────────────────────────────────────────────────────────────────
#
# Controls Probe signal collection behaviour engine-wide.
# Signal type config (which columns, fraction) belongs in each Blueprint's
# Probe module config.

probes:
  max_sample_rows: 100
  default_sample_fraction: 0.01

  # Probe signals that trigger a Spark action on a sample
  # (row_count_estimate/sample, null_rates, value_distribution, distinct_count)
  # are GATED by `danger.allow_full_probe_actions` — default false. Zero-cost
  # signals (schema_snapshot, partition_stats, sample_rows) always run.
  # data_freshness is also suppressed unless allow_sample: true is set per-signal.


# ── Metrics ───────────────────────────────────────────────────────────────────
#
# Per-module observability tuning. Aqueduct uses Spark `DataFrame.observe()` to
# collect accurate per-module row counts; SparkListener stage metrics are also
# collected unconditionally.

metrics:
  # When true (default), wrap each Ingress read / Egress write with
  # `DataFrame.observe()` for accurate per-module records_read / records_written.
  # When false, fall back to SparkListener stage metrics only — slightly less
  # accurate (stage fusion blurs attribution) but avoids a ~5–15% throughput
  # regression on high-throughput pipelines where `observe()` can break
  # whole-stage codegen. See docs/SPARK_GUIDE.md ("DataFrame.observe() and
  # Whole-Stage Codegen") for the tradeoff.
  use_observe: true


# ── Secrets ───────────────────────────────────────────────────────────────────
#
# @aq.secret('KEY') in Blueprints resolves via secrets.provider below.
# "env" reads os.environ — works for local dev, CI, and secret-injected envs
# (Kubernetes Secrets, AWS SSM + env export, etc.).
#
# ── .env file auto-loading ────────────────────────────────────────────────────
#
# EVERY command (run/doctor/validate/test/report/runs/lineage/signal/heal/
# benchmark/patch preview/stores info/stores migrate) auto-discovers a `.env`
# in the directory of the config/blueprint you pass (NOT cwd) and loads it
# into os.environ before config parsing. Existing env vars are never
# overwritten. A `(env: loaded N var(s) from …)` line is printed to stderr.
#
# Drop a `.env` next to this aqueduct.yml to avoid manual `export`. Names
# must be either a real env var the code reads (e.g. ANTHROPIC_API_KEY)
# or referenced in this file via ${VAR} / @aq.secret('KEY') — arbitrary
# names do nothing on their own:
#   ANTHROPIC_API_KEY=sk-ant-...     # read directly by the agent
#   MINIO_ACCESS_KEY=...             # used below as ${MINIO_ACCESS_KEY}
#   MINIO_SECRET_KEY=...             # used below as ${MINIO_SECRET_KEY}
#
# Precedence: -e KEY=VAL  >  real env  >  <dir>/.env  >  --env-file  >  default
#   aqueduct run pipeline.yml -e RUN_ENV=staging      # inline override
#   aqueduct run pipeline.yml --env-file secrets/.env # explicit fallback
#   AQ_NO_ENV_FILE=1 aqueduct run pipeline.yml        # disable discovery (CI)
#
# ── Environment variable substitution in aqueduct.yml itself ─────────────────
#
# aqueduct.yml supports two substitution syntaxes expanded before YAML parsing:
#   ${VAR}            — os.environ["VAR"]; error if unset
#   ${VAR:-default}   — os.environ["VAR"] if set, else "default"
#   ${VAR:default}    — same (dash optional)
#   @aq.secret('KEY')— resolved via the configured secrets.provider (Phase 32).
#                      Two-pass load: ${VAR} expands first, then secrets.provider
#                      is validated, then @aq.secret() is dispatched to the
#                      configured backend (env / aws / gcp / azure / custom).
#                      No os.environ caching — every call hits the provider so
#                      rotation + per-call audit are preserved.
#
# Resolved @aq.secret() values are registered with aqueduct.redaction and
# scrubbed as [REDACTED] from console, observability rows, patch sidecar
# files, webhook bodies (headers/URL untouched), and LLM request payloads.
# Short / low-entropy values (len < 8 OR Shannon entropy < 2.5 bits/char)
# are NOT registered and emit AQ-WARN [secret-weak-redact] instead — they
# would false-match common identifiers.
#
# Use these to avoid hardcoding credentials in aqueduct.yml:
#   agent:
#     provider: ${AQUEDUCT_LLM_PROVIDER:-openai_compat}
#     model: "@aq.secret('AQUEDUCT_LLM_MODEL')"
#     base_url: "@aq.secret('AQUEDUCT_LLM_BASE_URL')"

secrets:
  provider: "env"           # env | aws | gcp | azure | custom
  # region: "us-east-1"    # required for aws/gcp/azure — cloud region
  # resolver: "mypackage.secrets.fetch"  # custom provider: dotted import path
                                          # fn(key: str) -> str | None

  # ── AWS Secrets Manager (pip install aqueduct-core[aws]) ─────────────────────
  # provider: "aws"
  # region: "us-east-1"
  # Requires boto3. boto3 default credential chain: env vars
  # (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY [+ AWS_SESSION_TOKEN]),
  # ~/.aws/credentials profile, IAM role on EC2/ECS/EKS/Lambda (IMDS), SSO.
  # Secrets are fetched on every @aq.secret('KEY') call — no caching, so
  # provider-side rotation takes effect on the next config load.
  # Short secret name (KEY) or full ARN both accepted.

  # ── GCP Secret Manager (pip install aqueduct-core[gcp]) ──────────────────────
  # provider: "gcp"
  # region: "us-central1"   # optional for GCP
  # Requires google-cloud-secret-manager. ADC or GOOGLE_APPLICATION_CREDENTIALS.
  # Short names require GCP_PROJECT or GOOGLE_CLOUD_PROJECT env var.

  # ── Azure Key Vault (pip install aqueduct-core[azure]) ───────────────────────
  # provider: "azure"
  # Requires azure-keyvault-secrets + azure-identity. DefaultAzureCredential used.
  # Requires AZURE_KEYVAULT_URL env var (e.g. https://myvault.vault.azure.net/).

  # ── Custom provider ───────────────────────────────────────────────────────────
  # provider: "custom"
  # resolver: "mypackage.secrets.fetch_secret"
  # Callable: (key: str) -> str | None  (None = fall back to os.environ)


# ── Webhooks ──────────────────────────────────────────────────────────────────
#
# Blueprint-level push notifications. Delivery is best-effort (daemon thread);
# failures are logged and do not affect run outcome.
#
# Two hooks:
#   on_failure — fires when a run ends with status="error"
#   on_success — fires when a run ends with status="success"
#
# Per-module webhook: set on_failure_webhook on any module in the Blueprint.
#   Fires when that module's retry policy is exhausted, regardless of whether
#   the blueprint continues (alert_only) or stops.
#
# Per-Assert-rule webhook: use on_fail: {action: webhook, url: ...} in each
#   Assert rule inside the Blueprint.
#
# Simple form — just a URL; sends the full context payload as JSON via POST:
#   webhooks:
#     on_failure: "https://hooks.slack.com/services/T.../B.../"
#     on_success: "https://hooks.example.com/blueprint-complete"
#
# Full form — custom method, headers, and payload template.
#
# on_failure template variables:
#   ${run_id}          UUID of this blueprint run
#   ${blueprint_id}     Blueprint identifier string
#   ${blueprint_name}   Blueprint display name
#   ${failed_module}   Module ID where the first failure occurred
#   ${error_message}   Human-readable error description
#   ${error_type}      Exception class name (e.g. AnalysisException)
#   ${started_at}      ISO-8601 run start timestamp
#   ${attempt}         Number of failed modules in this run
#
# on_success template variables:
#   ${run_id}          UUID of this blueprint run
#   ${blueprint_id}     Blueprint identifier string
#   ${blueprint_name}   Blueprint display name
#   ${module_count}    Number of modules executed
#
# on_failure_webhook (per-module) template variables:
#   ${run_id}          UUID of this blueprint run
#   ${blueprint_id}     Blueprint identifier string
#   ${module_id}       ID of the module that failed
#   ${error_message}   Error description
#   ${error_type}      Exception class name
#
# ${ENV_VAR} in any value resolves to os.environ[VAR] (useful for secrets in headers).
#
# If payload is omitted, the full context JSON object is sent unchanged.

webhooks:
  on_failure: null
  on_success: null

  # ── Slack — notify on failure ────────────────────────────────────────────────
  # on_failure:
  #   url: "${SLACK_WEBHOOK_URL}"
  #   method: POST
  #   payload:
  #     text: "Blueprint *${blueprint_id}* failed on `${failed_module}` — ${error_message}"

  # ── Slack — notify on success ────────────────────────────────────────────────
  # on_success:
  #   url: "${SLACK_WEBHOOK_URL}"
  #   method: POST
  #   payload:
  #     text: "Blueprint *${blueprint_id}* complete (${module_count} modules)  run_id=${run_id}"

  # ── PagerDuty Events API v2 ──────────────────────────────────────────────────
  # on_failure:
  #   url: "https://events.pagerduty.com/v2/enqueue"
  #   method: POST
  #   headers:
  #     Authorization: "Token token=${PAGERDUTY_INTEGRATION_KEY}"
  #   payload:
  #     routing_key: "${PAGERDUTY_INTEGRATION_KEY}"
  #     event_action: trigger
  #     payload:
  #       summary: "${blueprint_name} failed: ${error_message}"
  #       severity: critical
  #       source: "aqueduct/${blueprint_id}"
  #       custom_details:
  #         run_id: "${run_id}"
  #         failed_module: "${failed_module}"

  # ── Generic webhook — full context payload (no template) ─────────────────────
  # on_failure:
  #   url: "https://ops.example.com/api/v1/aqueduct-failure"
  #   method: POST
  #   headers:
  #     Authorization: "Bearer ${OPS_API_TOKEN}"
  #     X-Source: "aqueduct"
  #   timeout: 15


# ── LLM Agent — Connection Defaults ──────────────────────────────────────────
#
# Sets the provider, endpoint, and model for all blueprints that enable LLM
# self-healing. Per-blueprint policy (approval_mode, forbidden_ops,
# on_pending_patches) belongs in each Blueprint's agent: block — see
# blueprint.yml.template.
#
# Blueprint agent: values override these defaults on conflict.
# If a blueprint omits agent: entirely, LLM self-healing is disabled.

agent:
  # ── Anthropic (default) ────────────────────────────────────────────────────
  provider: "anthropic"              # "anthropic" | "openai_compat"
  model: "claude-sonnet-4-6"
  # ANTHROPIC_API_KEY env var required at runtime

  # ── Timeouts and retries ──────────────────────────────────────────────────
  # timeout: 120.0              # HTTP socket timeout in seconds per agent call.
  #                             # Increase for slow local models (e.g. 600.0 for Qwen3-32B).
  # max_reprompts: 5            # Legacy single-axis cap; the unified loop also catches
  #                             # apply-gate rejections (guardrail / compile error) and
  #                             # feeds them back as reprompts. Use agent.budget below for
  #                             # finer-grained, multi-axis control.
  #                             # Does NOT retry on timeout/network failure (those abort immediately).

  # ── Multi-axis budget for the unified reprompt loop (1.1.0) ────────────────
  # First axis to trip terminates the loop. The terminal axis is recorded as
  # `stop_reason` in `heal_attempts` rows and on benchmark results — same
  # vocabulary across production and benchmark. `aqueduct benchmark` reads
  # this same block so the leaderboard runs under the production budget.
  #
  # budget:
  #   max_reprompts: 5            # max attempts (success counts as the terminating attempt)
  #   max_seconds: 120            # wall-clock cap across all attempts
  #   max_tokens_total: 50000     # null disables the axis
  #   same_error_consecutive: 2   # N identical signatures in a row → escalate (temp=0.8 + skeleton template)
  #                               # for ONE more attempt before tripping stuck_signature
  #   same_signature_overall: 3   # any signature repeating ≥ N times anywhere → stuck_signature
  #   progress_stalled_window: 3  # last N signatures identical → progress_stalled

  # ── Structured Spark error extraction (1.1.0) ──────────────────────────────
  # When the raised exception is a `PySparkException` / `Py4JJavaError`, the
  # Surveyor extracts the Spark `error_class`, offending column / table name,
  # `Did you mean ...?` suggestion list, and `SQLSTATE`. The LLM prompt renders
  # a focused "Root cause (structured)" block instead of the raw JVM stack
  # trace — substantially better recovery on small models. Persisted on
  # `failure_contexts.error_class / object_name / suggested_columns / sql_state
  # / root_exception`. Behaviour is automatic; no config knob required.

  # ── Custom prompt context ─────────────────────────────────────────────────
  # prompt_context: |           # Engine-wide context appended to LLM system prompt.
  #   This cluster runs Databricks. Use Delta Lake paths (dbfs:// or s3a://).
  #   All column names follow snake_case convention.
  #   Never reference local filesystem paths in config.path values.

  # ── Patch validation pyramid (Phase 29a) ───────────────────────────────────
  # patch_validation controls how rigorously auto/aggressive validates a
  # generated patch before writing it to the Blueprint on disk:
  #
  #   full_run (default, safest)
  #     the lineage gate (live sqlglot lineage diff) + the sandbox gate (sandbox replay against
  #     `--sample 1000` rows with Egress skipped) + full Spark run against the
  #     real Blueprint. Patch is written only when the full run succeeds.
  #
  #   sandbox
  #     the lineage gate + the sandbox gate only. Patch is written on sandbox pass without paying
  #     for a full real-data run. Fast unattended healing loop; lower
  #     confidence that the patch holds at production scale. Use only on
  #     pipelines whose data shape is well represented by the first 1000 rows.
  #
  # Per-blueprint override available via the Blueprint agent: block.
  # patch_validation: full_run

  # ── the explain gate strictness (Phase 29b) ──────────────────────────────────────────
  # block_on_explain_regression toggles whether the explain gate (post-patch `explain()`
  # regression check) is a hard blocker in aggressive mode. the explain gate compares
  # per-module `Exchange` / `BatchEvalPython` / `BroadcastExchange` counts in
  # the patched Manifest against the most recent baseline rolling-stored in
  # `observability.explain_snapshot`.
  #   false (default) — the explain gate prints warnings but never rejects a patch.
  #   true            — aggressive mode rejects a patch with any regression
  #                     (extra shuffle, extra Python UDF, lost broadcast hint).
  # Auto/human/disabled modes ignore this flag — the explain gate is informational there.
  # Per-blueprint override available via the Blueprint agent: block.
  # block_on_explain_regression: false

  # ── Spend-cap on LLM healing attempts ──────────────────────────────────────
  # Surveyor counts rows written to observability.db `healing_outcomes` within the last
  # 60 minutes for the running blueprint. When the count is reached, the next
  # LLM HTTP call is skipped and the run ends with a clear stderr message.
  # Default null = unlimited. Per-blueprint override available via the
  # Blueprint agent: block (Blueprint value wins).
  # max_heal_attempts_per_hour: 10

  # ── Ollama / vLLM / LM Studio (OpenAI-compatible endpoint) ────────────────
  # provider: "openai_compat"
  # base_url: "http://10.0.0.39:11434/v1"   # /v1 suffix required
  # model: "deepseek-r1:14b"
  # timeout: 600.0              # large local models need more time
  # provider_options:
  #   # Standard OpenAI params — merged into payload top-level (all openai_compat providers)
  #   temperature: 0.7
  #   top_p: 0.9
  #   # Ollama-specific params — prefix with ollama_ → stripped and nested under payload["options"]
  #   ollama_num_thread: 16
  #   ollama_num_gpu: 0          # 0 = CPU only; 99 = all on GPU
  #   ollama_mlock: true         # lock weights in RAM (no swap)
  #   ollama_num_batch: 1024     # prompt eval batch size
  #   ollama_num_predict: -1     # -1 = no token limit

# ── Warnings (Phase 30a) ──────────────────────────────────────────────────────
# Aqueduct emits compile-time and session-startup diagnostics with the format
#     AQ-WARN [rule_id] message
# Copy the bracketed rule_id straight from the terminal into the suppress list
# below to silence one rule. The single entry "*" silences ALL warnings.
# CLI: `aqueduct --suppress-warning <id> run bp.yml` (or '*'); goes BEFORE the
# subcommand. Merged on top of this list.
#
# Available compile-time rule IDs (registry: aqueduct/compiler/warnings/):
#   kafka_checkpoint_stale, nondeterministic_fanout,
#   count_col_likely_count_star, file_format_no_repartition,
#   jdbc_missing_partition
# Legacy (pre-30a) compile-time rules, also suppressible:
#   delivery_append_retry_dupes, perf_probe_sample_full_scan,
#   perf_incremental_watermark_scan, perf_python_udf_row_at_a_time,
#   perf_delta_append_no_partition, perf_multi_consumer_no_cache,
#   perf_hadoop_fs_in_options, maintenance_optimize_non_delta
# Session-startup rules (registry: aqueduct/executor/spark/warnings/):
#   jar_availability
#
# warnings:
#   suppress:
#     - count_col_likely_count_star
#     - jdbc_missing_partition
# # nuclear option — silence every Aqueduct warning:
# warnings:
#   suppress: ["*"]

# ── Danger settings ───────────────────────────────────────────────────────────
# All default to false (safe production mode). Set to true only when needed.
# Aqueduct prints a startup warning for any active danger setting.
#
# danger:
#   allow_aggressive_patching: false  # if true, approval_mode: aggressive is allowed
#                                     # (agent patches Blueprint without human review)
