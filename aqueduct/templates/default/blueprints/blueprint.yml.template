  #       - type: null_rates              # one action on sample
  #         columns: [order_id, amount]
  #         fraction: 0.05

  #       - type: sample_rows             # df.take(n) — bounded, not a full scan
  #         n: 20

  #       - type: value_distribution      # min/max/mean/stddev + percentiles on sample
