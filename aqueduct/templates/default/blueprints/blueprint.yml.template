# blueprint.yml — Blueprint Blueprint Template
#
# A Blueprint defines a single data blueprint: modules (data sources, transforms,
# sinks) and the edges connecting them. The engine compiles it into a Manifest
# and executes it on Spark.
#
# Key concepts:
#   @aq.*        Runtime tokens resolved at compile time (dates, secrets, depot)
#   ${ctx.*}     Blueprint context variables (resolved at parse time)
#   module.id    Unique identifier within this blueprint; used in edges and attach_to
#
# Usage:
#   aqueduct validate blueprint.yml
#   aqueduct compile  blueprint.yml
#   aqueduct run      blueprint.yml --config aqueduct.yml

aqueduct: "1.0"
id: my.blueprint.id          # dot-notation identifier; must be unique across your depot
name: "My Blueprint"
description: "Optional human-readable description"


# ── Context variables ─────────────────────────────────────────────────────────
#
# Resolved at parse time. Reference with ${ctx.key} anywhere in the Blueprint.
# Override at runtime: aqueduct run blueprint.yml --ctx env=prod --ctx date=2026-01-01

context:
  env: dev
  today: "@aq.date.today()"
  yesterday: "@aq.date.yesterday()"
  run_id: "@aq.run.id()"
  prev_run: "@aq.run.prev_id()"


# ── Context profiles ─────────────────────────────────────────────────────────
#
# Named context overrides. Activate with: aqueduct run ... --profile prod

context_profiles:
  prod:
    env: prod
  staging:
    env: staging


# ── SQL Macros ────────────────────────────────────────────────────────────────
#
# Reusable SQL fragments resolved at compile time. The Manifest always contains
# plain SQL — no macro syntax reaches the executor.
# Parameterized macros use {{ param_name }} placeholders.

macros:
  active: "status = 'active' AND deleted_at IS NULL"
  trunc:  "DATE_TRUNC('{{ period }}', {{ col }})"


# ── Spark config (blueprint-level overrides) ───────────────────────────────────
#
# Merged with engine spark_config at runtime; Blueprint values win on conflict.

spark_config:
  spark.sql.shuffle.partitions: "200"


# ── Retry policy (blueprint-level default) ─────────────────────────────────────
#
# Applied to every module unless overridden by a module-level `retry:` block
# (2.8, see the Modules section below) or the self-healer's `on_failure` write.

# retry_policy:
#   max_attempts: 3
#   backoff:                        # NOTE: nested block, not flat backoff_* keys
#     strategy: exponential         # exponential | linear | fixed
#     base_seconds: 5
#     max_seconds: 120
#     jitter: true
#   deadline_seconds: 600           # null = no deadline
#   on_exhaustion: abort            # abort | alert_only | trigger_agent
#   transient_errors:               # only these are retried (empty = all errors)
#     - ".*Connection reset.*"
#     - ".*Task not serializable.*"
#   non_transient_errors:           # these skip retry immediately
#     - "AnalysisException"
#
# Per-module override (2.8) — set `retry:` on any module in the `modules:`
# list below to override retry_policy for JUST that module. Any field left
# unset inherits the blueprint-level value above (field-by-field, same shape
# as agent.cascade tier inheritance). `backoff:` overrides as a WHOLE block
# (set every sub-field or omit it — it never merges field-by-field):
#
#   modules:
#     - id: flaky_jdbc_source
#       type: Ingress
#       label: "Flaky source"
#       config: { format: jdbc, ... }
#       retry:
#         max_attempts: 6          # override — more attempts for this module
#         # on_exhaustion, backoff, etc. inherit from retry_policy above


# ── Compile-warning suppression (per-blueprint) ─────────────────────────────────
#
# Silences compile-time warnings (rule_ids printed as
# `AQ-WARN [rule_id] ...`) for THIS blueprint only — merged (union) with the
# engine-level warnings.suppress in aqueduct.yml. Compile-time only: does not
# touch session-startup or runtime (Probe/Assert) warnings, and never affects
# other blueprints. On an Arcade sub-blueprint, this block is ignored — only
# the parent blueprint's suppress list covers the expanded compilation unit.

# warnings:
#   suppress:
#     - file_format_no_repartition
#     - jdbc_missing_partition
# # nuclear option — silence every compile warning for this blueprint:
# warnings:
#   suppress: ["*"]


# ── Lifecycle hooks ─────────────────────────────────────────────────────────────
#
# on_success / on_failure run sequentially AFTER the pipeline's terminal
# state. on_patch_pending / on_healed fire MID-RUN at heal milestones —
# on_patch_pending when a heal stages a patch for human/CI review,
# on_healed right after a heal's re-run succeeds (patch applied AND the
# pipeline is green again) — mirroring the engine-level `webhooks:`
# on_patch_pending/on_ci_patch vocabulary one level up, at the Blueprint.
# on_healed always fires before the outer run's terminal on_success hooks.
# Hook outcomes never change the run's exit code (a failing hook warns and
# skips the event's remaining hooks). Exactly one action per entry:
#   blueprint: <path>   chain another blueprint — by default a fresh
#                       `aqueduct run` subprocess (own run_id/report);
#                       `in_process: true` parses+compiles+executes the
#                       target in THIS process instead, reusing the live
#                       SparkSession (no self-healing loop for the target;
#                       falls back to the subprocess path when the target
#                       sets its own spark_config). Cycle-guarded, ungated.
#   webhook: <url|map>  same endpoint model as aqueduct.yml `webhooks:`
#                       (url shorthand, or url/method/headers/payload) — ungated
#   command: "<argv>"   subprocess (shlex, no shell); interpolates ${run.id},
#                       ${run.status}, ${blueprint.id} only. REQUIRES
#                       danger.allow_command_hooks: true in aqueduct.yml.
#
# when_error: [ErrorType, ...] — optional, on on_failure/on_patch_pending/
# on_healed entries only (on_success has no failure to match against —
# rejected at parse time). Fires only when the run's error_type / stack-
# trace exception class matches one of the listed names — same matching as
# agent.guardrails.heal_on_errors. Unset = fires unconditionally (default).

# hooks:
#   on_success:
#     - blueprint: blueprints/downstream.yml
#     - command: "scripts/commit_outputs.sh ${run.id}"
#       timeout: 120                  # seconds, default 300
#   on_failure:
#     - webhook: https://hooks.example/alert
#     - command: "scripts/cleanup_partial.sh ${run.id}"
#       when_error: ["EmptyDataset"]  # only fire for this Assert error_type
#   on_patch_pending:
#     - webhook: https://hooks.example/patch-review
#   on_healed:
#     - blueprint: blueprints/notify_healed.yml
#       in_process: true              # reuse this run's SparkSession


# ── Checkpointing ──────────────────────────────────────────────────────────────
#
# When true, every module's output is materialized to Parquet under
# <store_dir>/checkpoints/<run_id>/. Enables `aqueduct run --resume <run_id>`
# (modules with a valid checkpoint are reloaded and skipped) and avoids DAG
# re-computation for multi-consumer / incremental Channels. For finer control,
# set `checkpoint: true` on an individual module instead of blueprint-wide.

# checkpoint: false


# ── LLM self-healing policy ───────────────────────────────────────────────────
#
# Per-blueprint. Connection defaults (provider, model) come from aqueduct.yml.

agent:
  # approval controls what happens when the blueprint fails:
  #   disabled   — LLM never fires (default)
  #   human      — LLM generates patch → staged in patches/pending/ → run ends
  #                Review: aqueduct patch apply patches/pending/<id>.json --blueprint ...
  #   auto       — Auto-apply: patch applied in-memory → re-runs → written to disk only on success.
  #                `max_patches: 1` (default) = single-shot. `max_patches: N` (N > 1) = multi-patch
  #                reprompt loop; requires danger.allow_multi_patch: true in aqueduct.yml.
  #   ci         — Patch staged + POSTed to ci_webhook_url for external PR creation
  #
  approval: "human"

  on_pending_patches: "warn"      # ignore | warn | block
  max_patches: 1                  # 1 = single auto patch (default); > 1 enables the multi-patch loop
                                  # (needs danger.allow_multi_patch: true or --allow-multi-patch)

  # on_heal_failure: what to do when a patch is generated but the re-run still fails
  #   stage   — stage failed patch to patches/pending/ for human inspection (default)
  #   discard — silently discard, continue (multi-patch) or stop (single-patch)
  #   abort   — stop the healing loop immediately
  on_heal_failure: "stage"

  # allow_defer: permit the LLM to emit defer_to_human when the failure is
  # not healable at the Blueprint level. Default false — the LLM
  # must always produce a real patch unless explicitly permitted to defer.
  # allow_defer: true

  # deep_loop: run sandbox/lineage/explain gates inside the LLM conversation
  # so the model sees rejection feedback and retries in-context.
  # Default false — gates run post-hoc outside the conversation.
  # deep_loop: true

  # cascade: multi-model healing cascade. Each tier tries a
  # different model; escalates on stuck_signature / exhausted_attempts /
  # deferred. Cheaper model first, expensive model as fallback.
  # agent.budget.max_tokens_total spans the WHOLE cascade.
  # cascade:
  #   - model: qwen2.5-coder:7b
  #     max_reprompts: 2
  #     max_seconds: 30
  #   - model: claude-sonnet-4-6
  #     max_reprompts: 3
  #     max_seconds: 120
  #     deep_loop: true
  #     allow_defer: true
  #     api_key: "@aq.secret('ANTHROPIC_API_KEY')"  # per-tier key override
  #     supports_tools: true  # per-tier override; None inherits agent.supports_tools
  #
  # Shorthand: a model LIST expands to a default-settings cascade.
  # Mutually exclusive with an explicit cascade: block.
  # model: [qwen2.5-coder:7b, claude-sonnet-4-6]

  # confidence_threshold: LLM patches with confidence below this are escalated to human review
  confidence_threshold: 0.7

  # max_heal_attempts_per_hour: optional spend-cap. Surveyor refuses the next
  # LLM call once this many healing attempts have been recorded in observability.db
  # within the last 60 minutes for this blueprint. Default null = unlimited.
  # Overrides the engine-level agent.max_heal_attempts_per_hour in aqueduct.yml.
  # max_heal_attempts_per_hour: 10

  # patch_validation: override the engine-level validation level.
  #   full_run — the lineage gate + the sandbox gate + full Spark run (safest)
  #   sandbox  — the lineage gate + the sandbox gate only (fastest)
  # Leave unset to inherit aqueduct.yml agent.patch_validation.
  # patch_validation: full_run

  # block_on_explain_regression: when true, the explain gate (post-patch
  # `explain()` regression check) rejects patches in multi-patch mode
  # (max_patches > 1) that add shuffles / Python UDF nodes or drop broadcast
  # hints. Default false → the explain gate is warn-only. Leave unset to
  # inherit aqueduct.yml.
  # block_on_explain_regression: false

  # sandbox_mode (1.1.0+): how the sandbox gate replays a generated patch before
  # applying it. Default sample is right for almost every project.
  #   sample    — 1000-row replay per Ingress, Egress writes dropped (default)
  #   preflight — full-dataset replay, Egress writes dropped. Slow but conclusive.
  #               Requires danger.allow_full_preflight: true in aqueduct.yml.
  #   off       — skip the sandbox gate entirely. Patches hit real data via the
  #               next execute(). Requires danger.allow_skip_sandbox: true.
  #               Combining off + max_patches > 1 prints a
  #               ⚠ DANGER COMBO line at startup; use only on tiny trusted scopes.
  # sandbox_mode: sample

  # regression_artifact: on a SUCCESSFUL heal (patch applied AND the re-run
  # succeeded), optionally emit an `.aqtest.yml` regression test for the
  # patched module under `aqtests/` next to this Blueprint — guards against
  # the fix being silently undone later (hand-edit, SQL refactor, revert).
  # Conservative: skips (info log, no file) when the healed module/failure
  # shape can't be expressed as a valid aqtest. Never overwrites a file.
  # Leave unset to inherit aqueduct.yml agent.regression_artifact (= false).
  # regression_artifact: false

  # mode (agentic heal, opt-in): oneshot (default) is today's single
  # prompt → PatchSpec turn. agentic lets the model call READ-ONLY
  # diagnostic tools (run/patch/lineage history, the Blueprint YAML, a live
  # source schema, a small row sample) before answering — see docs/specs.md
  # §8.12. Leave unset to inherit aqueduct.yml agent.mode (= oneshot).
  # mode: oneshot
  # max_tool_calls: 8       # agentic mode only — cap per heal attempt
  # supports_tools: auto    # auto|true|false — tool-use capability probe

  # LLM Guardrails — per-blueprint restrictions on what the LLM may patch.
  # Violations → patch staged for human review instead of applied automatically.
  # NOTE: all four lists live under the `guardrails:` key, not directly on `agent:`.

  # guardrails:
  #   # allowed_paths: fnmatch patterns for config.path values the LLM may touch.
  #   #   Empty (default) = unrestricted.
  #   allowed_paths:
  #     - "s3a://my-bucket/prod/*"

  #   # forbidden_ops: PatchSpec ops the LLM may never use.
  #   #   Empty (default) = all ops permitted.
  #   #   Complete op list:
  #   #     set_module_config_key     update a single key in a module's config block
  #   #     replace_module_config     overwrite a module's entire config block
  #   #     replace_module_label      rename a module's display label
  #   #     insert_module             add a new module and rewire edges
  #   #     remove_module             delete a module and all its edges
  #   #     replace_context_value     change a context: variable
  #   #     add_probe                 add a Probe tapping an existing module
  #   #     replace_edge              change an edge's from / to / port
  #   #     set_module_on_failure     set per-module retry policy
  #   #     replace_retry_policy      replace the blueprint-level RetryPolicy
  #   #     add_arcade_ref            insert an Arcade (sub-Blueprint) reference
  #   #     defer_to_human            signal unhealable failure (requires allow_defer: true)
  #   #     set_spark_config          change a spark_config value (recommended: block in auto mode)
  #   #     replace_macro             replace an existing macros: body (recommended: block in auto mode)
  #   forbidden_ops:
  #     - remove_module
  #     - replace_retry_policy
  #     - set_spark_config          # recommended: spark config changes affect cluster resources
  #     - replace_macro             # recommended: one macro change can affect many modules

  #   # heal_on_errors: LLM only triggers when the failure matches one of these labels.
  #   #   Labels come from Assert rules' error_type field, or infrastructure exception class
  #   #   names extracted from the stack trace (e.g. "SparkException", "AnalysisException").
  #   #   Empty (default) = LLM triggers on all errors.
  #   heal_on_errors:
  #     - DataQualityViolation
  #     - SchemaError

  #   # never_heal_errors: LLM never triggers when the failure matches one of these labels.
  #   #   Takes priority over heal_on_errors. Useful to block LLM on known-unrecoverable errors.
  #   #   Empty (default) = no restriction.
  #   never_heal_errors:
  #     - SLABreach
  #     - OutOfDiskSpaceError

  # Override connection defaults for this blueprint only (all optional — unset = inherit from aqueduct.yml):
  # provider: "openai_compat"
  # base_url: "http://ollama.internal:11434/v1"
  # model: "claude-sonnet-4-6"
  # api_key: "@aq.secret('OPENAI_API_KEY')"       # optional; overrides engine-level api_key
  # timeout: 300.0               # seconds; increase for slow local models
  # provider_options: {}         # extra payload keys for openai_compat endpoints
  #                              # (ollama_* keys land in Ollama's options block)
  # max_reprompts: 5             # single-axis cap — prefer `budget:` below for multi-axis control
  #                              
  # Multi-axis budget (available at both engine and blueprint level):
  # budget:
  #   max_reprompts: 5
  #   max_seconds: 120
  #   max_tokens_total: 50000
  #   same_error_consecutive: 2
  #   same_signature_overall: 3
  #   progress_stalled_window: 3

  # prompt_context: |             # Appended to LLM system prompt after engine-level prompt_context.
  #   Green taxi schema uses lpep_* columns; yellow uses tpep_* columns.
  #   All output paths must stay within the data/ directory.


# ── Modules ───────────────────────────────────────────────────────────────────

# Replace [] with your module list — an empty modules list will run successfully
# but produce no output and write no data. Uncomment the examples below to start.
#
# Optional fields available on EVERY module (omitted from the examples below):
#   description: ""              # free-text, carried into the compiled Manifest
#   tags: [finance, daily]       # labels, carried into the compiled Manifest
#   depends_on: [other_module]   # ordering-only dependency — adds a DAG edge
#                                # without passing data (e.g. run after an Egress)
#   checkpoint: true             # per-module checkpoint (see blueprint-level note above)
#   enabled: ${ctx.run_exports}  # conditional execution (default true). Accepts a
#                                # bool or ${ctx.*}/${ENV} — flip per context profile.
#                                # Disabled modules are skipped (⏭) and the disable
#                                # cascades to every downstream consumer (a join/union
#                                # never runs with a missing input).
modules: []

  # ── INGRESS — load data from any Spark-supported source ──────────────────────

  # - id: raw_orders
  #   type: Ingress
  #   label: "Load raw orders"
  #   config:
  #     format: parquet               # any Spark format: parquet, delta, csv, json, jdbc, orc, avro...
  #     table: "unity.sales.orders"   # OR: catalog.schema.table (mutually exclusive with path)
  #     path: "s3a://bucket/orders/date=${ctx.today}/"
  #     partition_filters: "event_date >= '${ctx.start_date}'"   # manual predicate pushdown hint
  #     options: {}                 # forwarded verbatim to df.read.options()
  #     schema_hint: {id: long, val: integer}  # flat form — checks presence + type
      
  #     schema_hint:                # strict mode (default) — all hinted columns must exist + match type
  #       columns:
  #         - name: order_id
  #           type: long
  #         - name: amount
  #           type: double
  #
  #     schema_hint:                # additive mode — extra upstream columns allowed (schema evolution)
  #       mode: additive
  #       columns:
  #         - name: order_id
  #           type: long
  #
  #     schema_hint:                # subset mode — missing optional columns allowed
  #       mode: subset
  #       columns:
  #         - name: amount
  #           type: double
  #
  #   # Per-module retry override (overrides blueprint-level retry_policy):
  #   on_failure:
  #     max_attempts: 5
  #     backoff_strategy: exponential
  #     on_exhaustion: alert_only   # blueprint continues even if this module fails
  #
  #   # on_failure_webhook: fires when retry is exhausted (regardless of on_exhaustion).
  #   # Simple form: URL only (POSTs full context JSON)
  #   on_failure_webhook: "https://hooks.slack.com/services/T.../B.../"
  #
  #   # Full form: custom method, payload, and headers
  #   on_failure_webhook:
  #     url: "${SLACK_WEBHOOK_URL}"
  #     method: POST
  #     headers:
  #       Authorization: "Bearer ${OPS_TOKEN}"
  #     payload:
  #       text: "Module *${module_id}* failed in *${blueprint_id}*: ${error_message}"
  #     timeout: 10
  #
  #   # Available template variables:
  #   #   ${run_id}          - Run UUID
  #   #   ${blueprint_id}     - Blueprint ID
  #   #   ${module_id}        - Module ID (this module)
  #   #   ${error_message}    - Error description
  #   #   ${error_type}       - Exception class name


  # ── CHANNEL — SQL transform ───────────────────────────────────────────────────

  # - id: clean_orders
  #   type: Channel
  #   label: "Remove invalid rows"
  #   config:
  #     op: sql                       # sql | join
  #     query: |
  #       SELECT *
  #       FROM raw_orders
  #       WHERE amount IS NOT NULL
  #         AND {{ macros.active }}
  #         AND {{ macros.trunc(period='day', col=order_ts) }} >= '2026-01-01'
  #     spillway_condition: "amount IS NULL OR order_ts IS NULL"  # bad rows → spillway port
  #     # metrics_boundary: true      # force Spark stage cut → accurate per-module recordsWritten metrics
  #     #   Without this, stage fusion groups logical modules into one physical stage, making
  #     #   SparkListener attribution inaccurate. Enable when per-module metrics matter (e.g.
  #     #   LLM self-healing uses recordsWritten to detect empty-output failures).


  # ── CHANNEL — incremental processing (watermark-based) ───────────────────────
  #
  # Processes only new rows each run. The last MAX(watermark_column) is persisted
  # in Depot and injected as ${ctx._watermark} at runtime.
  # First run sentinel: '1900-01-01 00:00:00' (full scan). Use mode: append downstream.

  # - id: new_orders
  #   type: Channel
  #   config:
  #     op: sql
  #     materialize: incremental
  #     watermark_column: event_ts     # column whose MAX tracks progress
  #     query: |
  #       SELECT *
  #       FROM source_orders
  #       WHERE event_ts > CAST('${ctx._watermark}' AS TIMESTAMP)


  # ── CHANNEL — join syntax (alternative to raw SQL JOIN) ───────────────────────

  # - id: enrich_orders
  #   type: Channel
  #   config:
  #     op: join
  #     left: raw_orders
  #     right: customers_ingress
  #     join_type: left             # inner | left | right | full | semi | anti | cross
  #     condition: "raw_orders.customer_id = customers_ingress.id"
  #     broadcast_side: right       # optional: BROADCAST hint for smaller side


  # ── JUNCTION — split one DataFrame into named branches ────────────────────────

  # - id: split_by_region
  #   type: Junction
  #   label: "Split by region"
  #   config:
  #     mode: conditional             # conditional | broadcast | partition
  #     branches:
  #       - id: us
  #         condition: "region = 'US'"
  #       - id: eu
  #         condition: "region = 'EU'"
  #       - id: other
  #         condition: "_else_"       # everything not matched above


  # ── FUNNEL — merge multiple DataFrames ───────────────────────────────────────

  # - id: merged_output
  #   type: Funnel
  #   label: "Merge EU and US"
  #   config:
  #     mode: union_all               # union_all | union | coalesce | zip
  #     inputs:
  #       - split_by_region.us
  #       - split_by_region.eu
  #     schema_check: strict          # strict | permissive


  # ── PROBE — observability tap (never halts blueprint) ─────────────────────────
  #
  # Attaches to a module's output edge. Writes signals to signals.db.
  # schema_snapshot also writes a JSON file to store_dir/signals/<run_id>/.

  # - id: probe_after_clean
  #   type: Probe
  #   label: "Capture quality signals after cleaning"
  #   attach_to: clean_orders
  #   config:
  #     report: stdout                  # optional — also print signal results under this
  #                                     # module in the run summary (dim ↳ lines, capped
  #                                     # at 10 unless -v). Persistence is unchanged.
  #     signals:
  #       - type: schema_snapshot         # zero Spark action — metadata only

  #       - type: row_count_estimate      # method: spark_listener = zero cost (from stage metrics)
  #         method: spark_listener        # method: sample = count() on a fraction

  #       - type: null_rates              # one action on sample
  #         columns: [order_id, amount]
  #         fraction: 0.05

  #       - type: sample_rows             # df.take(n) — bounded, not a full scan
  #         n: 20

  #       - type: value_distribution      # min/max/mean/stddev + percentiles on sample
  #         columns: [amount]             # omit → all numeric columns
  #         fraction: 0.1
  #         percentiles: [0.25, 0.5, 0.75]

  #       - type: distinct_count          # approx_count_distinct per column on sample
  #         columns: [region, status]     # omit → all columns
  #         fraction: 0.1

  #       - type: data_freshness          # max(column) — full scan by default
  #         column: order_ts             # required; timestamp or date column
  #         # allow_sample: true         # trades accuracy for speed in production
  #         # fraction: 0.1

  #       - type: partition_stats         # df.rdd.getNumPartitions() — zero Spark action


  # ── REGULATOR — gate that blocks downstream on false signal ──────────────────
  #
  # Passive by default — compiled away entirely if no signal edge is wired.
  # Wire a Probe's signal port to this module to activate it.

  # - id: quality_gate
  #   type: Regulator
  #   label: "Block downstream if quality signal is False"
  #   config:
  #     on_block: skip                # skip | abort | trigger_agent


  # ── ASSERT — inline data quality rules ───────────────────────────────────────
  #
  # Evaluates rules against the flowing DataFrame inline.
  # Aggregate rules batched into ≤2 Spark actions regardless of rule count.
  # Row-level rules (sql_row, custom) are lazy filters — no additional actions.

  # - id: orders_quality
  #   type: Assert
  #   label: "Enforce business rules"
  #   config:
  #     rules:
  #       - type: schema_match
  #         expected: {order_id: long, amount: double}
  #         on_fail: abort            # abort | warn | webhook | trigger_agent
  #         error_type: SchemaError   # optional typed label for guardrail matching

  #       - type: min_rows
  #         min: 1000
  #         on_fail: abort
  #         error_type: EmptyDataset  # optional; matched by heal_on_errors / never_heal_errors

  #       - type: max_rows
  #         max: 10000000
  #         on_fail: warn

  #       - type: null_rate
