  #       SELECT *
  #       FROM source_orders
  #       WHERE event_ts > CAST('${ctx._watermark}' AS TIMESTAMP)


  # ── CHANNEL — join syntax (alternative to raw SQL JOIN) ───────────────────────

  # - id: enrich_orders
  #   type: Channel
  #   config:
  #     op: join
  #     left: raw_orders
  #     right: customers_ingress
  #     join_type: left             # inner | left | right | full | semi | anti | cross
  #     condition: "raw_orders.customer_id = customers_ingress.id"
  #     broadcast_side: right       # optional: BROADCAST hint for smaller side


  # ── JUNCTION — split one DataFrame into named branches ────────────────────────

  # - id: split_by_region
  #   type: Junction
  #   label: "Split by region"
