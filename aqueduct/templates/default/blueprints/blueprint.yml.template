  # ── UDF registry ─────────────────────────────────────────────────────────────

# Python UDF — module must be importable from project root (udfs/ dir or any package)
udf_registry: [] 
  # - id: parse_phone
  #   lang: python
  #   module: udfs.parse_phone       # dotted module path relative to project root
