# Aqueduct Scenario Template — all possible fields documented
# Used with: aqueduct heal --scenario <file>
#            aqueduct benchmark --scenarios <dir>
#
# A scenario defines a simulated pipeline failure + assertions on what the
# LLM healing agent should produce. No Spark required to run.

aqueduct_scenario: "1.0"

# ── Identity ──────────────────────────────────────────────────────────────────

id: my_scenario_id                 # unique slug; used in benchmark table headers
description: >
  One sentence explaining the failure scenario and what the LLM should fix.

# ── Blueprint reference ───────────────────────────────────────────────────────

# Path to the blueprint YAML, resolved relative to this scenario file.
# Aqueduct parses + compiles it (no Spark) to produce a realistic manifest_json
# for the LLM prompt. The blueprint does not need to run successfully.
#
# If the blueprint declares `agent.guardrails` (forbidden_ops, allowed_paths,
# heal_on_errors, never_heal_errors), they are now injected into the LLM
# prompt as constraints AND enforced by `_check_guardrails` in the scenario
# apply path — matching production. Scenarios with no guardrails are excluded
# from the "Guardrail-clean rate" leaderboard metric.
blueprint: ../blueprints/pipeline.yml

# ── Injected failure ──────────────────────────────────────────────────────────

inject_failure:
  # module_id of the failing module (sets failed_module in FailureContext)
  module: my_ingress_module

  # Full error message as it would appear in the run log
  error_message: >
    IngressError: [my_ingress_module] source not found or unreadable
    at 'data/orders.parquet': AnalysisException: Unable to infer schema

  # Optional: stack trace (multi-line string)
  stack_trace: |
    Traceback (most recent call last):
      File "aqueduct/executor/spark/ingress.py", line 61, in read_ingress
        df = reader.load(path)
      File "pyspark/sql/readwriter.py", line 228, in load
        return self._df(self._jreader.load(path))
    AnalysisException: Unable to infer schema for Parquet.

  # Optional: structured Spark error fields (1.1.0+). When present, the prompt
  # builder renders a "Root cause (structured)" block instead of the raw stack
  # trace — same shape that production extracts from a live PySparkException
  # via surveyor._extract_structured_error. Lets benchmark scenarios exercise
  # the identical prompt branch the agent sees in production.
  # structured:
  #   error_class: UNRESOLVED_COLUMN.WITH_SUGGESTION   # Spark condition or innermost throwable class
  #   sql_state: "42703"                                # optional getSqlState()
  #   object_name: event_ts                             # offending column / table / relation
  #   suggested_columns: [event_id, event_time, user_id, event_type]
  #   root_exception:
  #     type: org.apache.spark.sql.AnalysisException
  #     message: "[UNRESOLVED_COLUMN.WITH_SUGGESTION] ..."

# ── Expected patch (effect-based grader, Phase 33 Part B Scope C) ─────────────
#
# The grader checks the EFFECT of the patch — the post-patch blueprint's
# target module config — rather than op-name equality on the raw patch.
# Any valid op (set_module_config_key, replace_module_config, etc.) that
# lands the right end state passes. SQL-typed fields (`query`, `sql`) are
# compared via sqlglot AST normalization so whitespace, quoting, and
# alias-case differences don't trip false fails.
#
# Omit the `expected_patch:` block entirely (or set it to {}) when the
# scenario has multiple valid fixes that touch different modules — the
# scenario then gates on `patch_applies` + `root_cause_contains` only.
#
# The legacy `expected_patch.ops:` / `expected_patch.forbidden_ops:` syntax
# was DELETED in 1.0.3 — scenarios using it now fail with a migration hint.

expected_patch:
  effect:
    module: my_ingress_module          # post-patch must contain this module by id
    config_contains:
      format: "csv"                    # raw substring on string fields
      header: true                     # equality on bool / number fields
      # query: "event_time"            # SQL-typed key → sqlglot-AST-normalized substring

# ── Assertions ────────────────────────────────────────────────────────────────

assertions:

  # PatchSpec must parse without schema validation error.
  # If false and patch parses: fail. If true and patch is None: fail.
  - patch_is_valid: true

  # Patch must be applicable to the blueprint (parse + compile with patch applied).
  # Also runs `_check_guardrails` when the blueprint declares `agent.guardrails`,
  # so a guardrail-violating patch is reported as `patch_applies: false`
  # here — matching production. Disabled automatically when blueprint path
  # not found.
  - patch_applies: true

  # LLM must produce a valid PatchSpec on the first call (no reprompts needed).
  # Failure here means: LLM knew the answer but couldn't format it correctly.
  # Distinguishes "correct + well-formatted" from "correct after coaching".
  # - max_attempts: 1

  # LLM self-reported confidence must be at or above this threshold.
  # - min_confidence: 0.8

  # LLM must classify the failure into the correct category.
  # Valid categories: schema_drift, bad_path, format_mismatch, oom_config,
  #   sql_column_not_found, type_mismatch, missing_context, permission_error, other
  # - expected_category: format_mismatch

  # LLM's root_cause field must contain at least one keyword (case-insensitive substring).
  # Accepts a single string or a list — any match passes.
  # Tests diagnostic quality, not just patch op correctness.
  # Used together with expected_category for the "Diag-only rate" benchmark metric:
  # scenarios where the LLM correctly identified the cause but generated a wrong op.
  # - root_cause_contains: "format"
  # - root_cause_contains: ["format", "parquet", "schema"]  # any one match passes
